        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam shadowing true\nskinparam roundcorner 20\nskinparam dpi 150\n\nskinparam state {\n    BackgroundColor #EAF2F8\n    BorderColor #2E86C1\n    FontSize 13\n}\n\n[*] --&gt; KhoiTao\n\nstate \&quot;Xử lý đơn hàng\&quot; as XL {\n    [*] --&gt; XacNhan\n    XacNhan --&gt; CheBien\n    CheBien --&gt; PhucVu\n}\n\nKhoiTao --&gt; XL\n\nXL --&gt; ThanhToan\n\nstate ThanhToan {\n    [*] --&gt; ChoThanhToan\n    ChoThanhToan --&gt; DaThanhToan : Thành công\n    ChoThanhToan --&gt; ThatBai : Thất bại\n}\n\nThanhToan --&gt; HoanTat\nHoanTat --&gt; [*]\n\n&#39; Màu\nstate KhoiTao #AED6F1\nstate XacNhan #F9E79F\nstate CheBien #FAD7A0\nstate PhucVu #D5F5E3\nstate ChoThanhToan #FDEBD0\nstate DaThanhToan #ABEBC6\nstate ThatBai #F1948A\nstate HoanTat #D2B4DE\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="AqFY2uYe4NTlKMxWill8-6">
