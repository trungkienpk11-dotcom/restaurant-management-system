<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36" pages="7">
  <diagram id="BMjKw67clBOzEWoFgODP" name="Trang-2">
    <mxGraphModel dx="1030" dy="596" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nleft to right direction\nskinparam shadowing true\nskinparam roundcorner 15\nskinparam dpi 150\n\nskinparam defaultFontName Arial\nskinparam defaultFontSize 13\n\nskinparam usecase {\n    BackgroundColor #E8F6F3\n    BorderColor #1ABC9C\n}\n\nskinparam rectangle {\n    BackgroundColor #E8F8F5\n    BorderColor #16A085\n}\n\nactor Customer #AED6F1\nactor Waiter #F9E79F\nactor Cashier #F5B7B1\n\nrectangle \&quot;Restaurant System\&quot; {\n\n    usecase \&quot;Xem menu\&quot; as UC1\n    usecase \&quot;Gọi món\&quot; as UC2\n    usecase \&quot;Nhập order\&quot; as UC3\n    usecase \&quot;Xử lý đơn hàng\&quot; as UC4\n    usecase \&quot;Phục vụ món\&quot; as UC5\n    usecase \&quot;Thanh toán\&quot; as UC6\n    usecase \&quot;Tạo hóa đơn\&quot; as UC7\n}\n\nCustomer --&gt; UC2\nCustomer --&gt; UC6\n\nWaiter --&gt; UC1\nWaiter --&gt; UC3\nWaiter --&gt; UC5\n\nCashier --&gt; UC6\nCashier --&gt; UC7\n\nUC2 --&gt; UC3 : &lt;&lt;include&gt;&gt;\nUC3 --&gt; UC4 : &lt;&lt;include&gt;&gt;\nUC4 --&gt; UC5 : &lt;&lt;include&gt;&gt;\nUC6 --&gt; UC7 : &lt;&lt;include&gt;&gt;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="gqtMV7_FDcx86swllYNl-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="320" width="806.31" x="130" y="90" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="VXhDzp8hNYda3kJOacTL" name="Trang-3">
    <mxGraphModel dx="1030" dy="596" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam shadowing true\nskinparam roundcorner 15\nskinparam dpi 150\n\nskinparam class {\n    BorderColor #2E86C1\n}\n\nclass Customer #D6EAF8 {\n    -customerID: int\n    -name: string\n    -phone: string\n}\n\nclass Order #D5F5E3 {\n    -orderID: int\n    -date: datetime\n    -status: string\n}\n\nclass OrderDetail #FCF3CF {\n    -quantity: int\n    -price: double\n}\n\nclass MenuItem #FAD7A0 {\n    -itemID: int\n    -name: string\n    -price: double\n}\n\nclass Bill #F5B7B1 {\n    -billID: int\n    -total: double\n    -paymentMethod: string\n}\n\nCustomer \&quot;1\&quot; -- \&quot;0..*\&quot; Order\nOrder \&quot;1\&quot; *-- \&quot;1..*\&quot; OrderDetail\nOrderDetail \&quot;*\&quot; -- \&quot;1\&quot; MenuItem\nOrder \&quot;1\&quot; -- \&quot;1\&quot; Bill\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="gP173NqO6dk4rTTqg6iK-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="660" width="398.52" x="110" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="pNiEkg4vDLiLHGzVMlih" name="Trang-4">
    <mxGraphModel dx="1030" dy="596" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam shadowing true\nskinparam roundcorner 15\nskinparam dpi 150\n\nactor Customer #AED6F1\nparticipant Waiter #F9E79F\nparticipant System #ABEBC6\nparticipant Kitchen #F8C471\nparticipant Cashier #F5B7B1\n\nCustomer -&gt; Waiter : Gọi món\nWaiter -&gt; System : Nhập order\n\nloop Gọi thêm món\n    Customer -&gt; Waiter : Thêm món\n    Waiter -&gt; System : Cập nhật order\nend\n\nSystem -&gt; Kitchen : Gửi yêu cầu chế biến\nKitchen -&gt; System : Hoàn thành món\n\nSystem -&gt; Waiter : Thông báo phục vụ\nWaiter -&gt; Customer : Phục vụ món\n\nCustomer -&gt; Cashier : Thanh toán\n\nalt Tiền mặt\n    Cashier -&gt; System : Tạo hóa đơn\nelse Online\n    Customer -&gt; System : Thanh toán online\nend\n\nSystem -&gt; Cashier : Xác nhận\nCashier -&gt; System : Cập nhật trạng thái\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="ljx-Mvw_Fa37M6ctWZoX-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="630" width="576.52" x="60" y="30" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="m9XSko8KejAKdGOjZuXZ" name="Trang-5">
    <mxGraphModel dx="896" dy="518" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam shadowing true\nskinparam roundcorner 15\nskinparam dpi 150\n\nskinparam activity {\n    BackgroundColor #EBF5FB\n    BorderColor #2E86C1\n    DiamondBackgroundColor #F9E79F\n}\n\nstart\n\n:Khách vào quán;\n\n:Chọn món;\n\nif (Món còn?) then (Yes)\n  :Gọi món;\nelse (No)\n  :Chọn món khác;\nendif\n\n:Nhân viên nhập hệ thống;\n\n:Chuyển đơn xuống bếp;\n\n:Bếp chế biến;\n\n:Phục vụ món;\n\nif (Gọi thêm?) then (Yes)\n  :Quay lại gọi món;\nendif\n\n:Thanh toán;\n\nif (Phương thức?) then (Tiền mặt)\n  :Thanh toán tiền mặt;\nelse (Online)\n  :Thanh toán online;\nendif\n\nstop\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="T-Rn3csVxtCCCCqww-tv-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
